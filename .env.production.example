NODE_ENV=production
GOLANDING_ACCESS_SECRET=replace-with-long-random-secret
GOLANDING_ADMIN_EMAILS=computerschool100@gmail.com
GOLANDING_DB_PROVIDER=postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
GOLANDING_DB_SSL=require
GOLANDING_STORAGE_PROVIDER=s3
S3_REGION=ap-northeast-2
S3_BUCKET=golanding-assets
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=https://cdn.example.com
S3_ACCESS_KEY_ID=replace-with-access-key
S3_SECRET_ACCESS_KEY=replace-with-secret-key
S3_FORCE_PATH_STYLE=false
